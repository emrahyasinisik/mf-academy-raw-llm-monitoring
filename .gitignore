# Monorepo root ignores (per-package .gitignore files also apply)

# Env / secrets
**/.env
**/.env.local
**/.env.*.local

# Node / Next.js
**/node_modules/
**/.next/
**/out/

# Go build artifacts (anchored paths — must NOT match Next.js src/app or cmd/server)
mf-backend/app
mf-backend/mf-backend
mf-backend/server

# Misc
.DS_Store
*.log
