# Copy to .env and fill in. Never commit the real .env.

# Grafana's admin login. The UI is bound to 127.0.0.1 only, but a weak password
# on a monitoring console is still a bad habit to build.
GRAFANA_USER=admin
GRAFANA_PASSWORD=

# ---------------------------------------------------------------------------
# The scrape token is NOT set here.
#
# Prometheus does no environment expansion in its config file, so the token has
# to be a file it can read. Create it next to the config:
#
#   printf '%s' 'the-same-token-as-the-backend' > prometheus/metrics-token
#
# It must match METRICS_TOKEN in the backend's environment exactly — no trailing
# newline, which is why printf is used rather than echo. The file is gitignored.
# ---------------------------------------------------------------------------
