# Copy to .env and fill in. Never commit the real .env.

# Shared secret the Go backend sends as X-API-Key. Generate a long random value:
#   PowerShell:  [Convert]::ToBase64String((1..32|%{Get-Random -Max 256}))
# The same value goes into the backend's LLM_API_KEY.
LLM_API_KEY=

# Token from the Cloudflare Zero Trust dashboard when you create the tunnel
# (Networks -> Tunnels -> Create a tunnel -> Docker). It embeds the tunnel's
# credentials, so treat it like a password.
TUNNEL_TOKEN=

# The model to serve. Must be an MLC-compiled repo; the id matches the browser
# catalog in mf-backend/internal/llm/handler.go so the same model can be
# compared across targets.
MLC_MODEL=HF://mlc-ai/gemma-2-2b-it-q4f16_1-MLC

# CUDA wheel tag. Must match the base image in mlc/Dockerfile.
CUDA_TAG=cu122
