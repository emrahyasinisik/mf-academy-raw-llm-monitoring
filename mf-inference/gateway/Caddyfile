# Gateway in front of mlc_llm serve.
#
# mlc_llm has no authentication of its own. Without something in front, anyone
# who learns the tunnel hostname can run inference on the card for free — so
# this is not optional hardening, it is the only thing standing between the GPU
# and the open internet.

{
	admin off
	# Cloudflare terminates TLS at the tunnel edge; this hop is plain HTTP
	# inside the compose network.
	auto_https off
}

:8080 {
	# `route` evaluates directives in written order. Without it Caddy would sort
	# by matcher specificity and the health check could end up behind the auth
	# check, which is the opposite of what we want.
	route {
		# Unauthenticated: lets cloudflared and the Go backend probe liveness
		# without holding the secret. Reveals nothing but the word "ok".
		respond /health "ok" 200

		@unauthorized not header X-API-Key {env.LLM_API_KEY}
		respond @unauthorized "unauthorized" 401

		reverse_proxy {
			# Load balancer across however many mlc replicas are running.
			#
			# `dynamic a` rather than a plain `reverse_proxy mlc:8000`: the plain
			# form resolves DNS once at startup, so `docker compose up --scale
			# mlc=3` would silently keep sending everything to the one replica
			# that existed when Caddy booted. This form re-resolves, so replicas
			# added or removed while running are picked up.
			dynamic a {
				name mlc
				port 8000
				refresh 10s
			}

			# round_robin, chosen after least_conn measurably failed here.
			#
			# least_conn is the better fit on paper: generation times vary by an
			# order of magnitude, so sending work to whichever replica is free
			# beats sending it in turn. In practice every request still went to
			# the first replica, including two that overlapped for three full
			# seconds — measured, not assumed. The likely reason is that
			# least_conn needs a per-upstream count of active requests, and the
			# dynamic-a module rebuilds its upstream list as it resolves, so the
			# counts it compares are not the ones that accumulated.
			#
			# round_robin needs no such state: it advances a position each time.
			# A short request can land behind a long one, which is the cost of
			# this choice — but a policy that distributes imperfectly beats one
			# that leaves half the hardware idle.
			lb_policy round_robin

			# A replica that is still loading weights answers nothing useful for
			# the first minute or so. Active checks keep it out of rotation
			# until it can serve, which is what makes `--scale` safe to run
			# against live traffic rather than a restart everyone notices.
			health_uri /v1/models
			health_interval 15s
			health_timeout 5s

			# Passive checks catch a replica that accepts connections but has
			# fallen over — two failures parks it for half a minute.
			fail_duration 30s
			max_fails 2

			# Generation on a 6 GB card can take far longer than Caddy's default
			# read timeout. This bound must stay above the Go side's LLM_TIMEOUT,
			# or the gateway cuts the response before the backend gives up and
			# the user sees a confusing 502 instead of a timeout.
			transport http {
				response_header_timeout 180s
				read_timeout 180s
			}
		}
	}

	log {
		output stdout
		format console
	}
}
