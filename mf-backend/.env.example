# Copy to .env for local development. Do NOT commit real secrets.
APP_ENV=development
PORT=8080

# Local Postgres (Homebrew). On Render this is provided automatically.
DATABASE_URL=postgres://emrah@localhost:5432/mf_monitoring?sslmode=disable

# This value is fine for local development and ONLY for local development: it
# is public, so with APP_ENV=production the server refuses to start on it.
# Generate a real one with `openssl rand -base64 48` (32 bytes minimum).
JWT_SECRET=dev-insecure-secret-change-me
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=168h

# Comma-separated allowed frontend origins. "*" is rejected in production.
CORS_ORIGINS=http://localhost:3000

# Set to true only when a proxy you control (Render, nginx, a load balancer)
# sits in front of this process and sets X-Forwarded-For. Leaving it false
# behind a proxy makes every client share one rate-limit bucket; setting it
# true without a proxy lets any caller forge their own IP.
TRUST_PROXY=false

# Upper bound on a single request, database work included.
REQUEST_TIMEOUT=5s

# bcrypt work factor. Each step doubles the CPU spent per login (~50ms at 10,
# ~200ms at 12 on an M3). Lower it on a throttled shared vCPU if logins drag;
# values below 10 are refused.
BCRYPT_COST=12

APP_NAME=MasterFabric Raw LLM Monitoring & Decision Scoring
APP_VERSION=0.1.0
